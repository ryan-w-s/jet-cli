{
  "name": "@just-easy-tasks/jet",
  "version": "0.1.3",
  "description": "Command line task management for Just Easy Tasks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryan-w-s/jet-cli.git"
  },
  "bugs": {
    "url": "https://github.com/ryan-w-s/jet-cli/issues"
  },
  "homepage": "https://github.com/ryan-w-s/jet-cli#readme",
  "keywords": [
    "jet",
    "tasks",
    "issue-tracker",
    "cli",
    "agents"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "jet": "dist/jet.js"
  },
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:api": "bun run src/scripts/generate-api.ts",
    "generate:docs": "bun run src/scripts/generate-docs.ts",
    "check:schema": "bun run src/scripts/check-schema.ts",
    "smoke:api": "bun run src/scripts/smoke-api.ts",
    "smoke:package": "bun run src/scripts/smoke-package.ts",
    "build": "bun build src/cli.ts --outfile dist/jet.js --target node",
    "pack:check": "bun run build && bun run smoke:package && bun pm pack --dry-run",
    "check": "bun run typecheck && bun test && bun run check:schema && bun run build && bun run smoke:package && bun run smoke:api",
    "prepublishOnly": "bun run check"
  },
  "files": [
    "dist",
    "README.md",
    "openapi.json",
    "skills"
  ],
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^25.6.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "openapi-fetch": "^0.17.0"
  }
}
