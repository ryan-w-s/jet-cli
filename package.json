{
  "name": "jet-cli",
  "version": "0.1.0",
  "description": "Command line interface for Just Easy Tasks",
  "bin": {
    "jet": "./dist/jet.js"
  },
  "module": "src/cli.ts",
  "type": "module",
  "private": false,
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "generate:api": "bun run src/scripts/generate-api.ts",
    "build": "bun build src/cli.ts --outfile dist/jet.js --target node"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "openapi-fetch": "^0.17.0"
  }
}
